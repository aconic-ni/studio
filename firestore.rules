
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the currently authenticated user is an admin.
    // It reads the 'role' field from the user's own document in the 'users' collection.
    function isAdmin() {
      // Ensure the user is authenticated.
      if (request.auth.uid == null) {
        return false;
      }
      // Construct the path to the user's document.
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      // Check if the user's document exists.
      if (!exists(userDocPath)) {
        return false;
      }
      // Return true if the user's role is 'admin'.
      return get(userDocPath).data.role == 'admin';
    }

    // Helper function to get the role of the currently authenticated user.
    function getRequestingUserRole() {
      // Ensure the user is authenticated.
      if (request.auth.uid == null) {
        return null;
      }
      // Construct the path to the user's document.
      let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
      // Check if the user's document exists.
      if (!exists(userDocPath)) {
        return null;
      }
      // Return the user's role.
      return get(userDocPath).data.role;
    }

    // Rules for the 'users' collection.
    match /users/{userId} {
      // A user can read their own document.
      // An admin can read any user document.
      allow get: if request.auth.uid == userId || isAdmin();

      // An admin can list all user documents.
      allow list: if isAdmin();

      // An admin can create user documents.
      // (Allowing users to create their own document typically happens during sign-up
      // and would require more specific rules, e.g., request.auth.uid == userId
      // and checking incoming data. For now, focusing on admin creation).
      allow create: if isAdmin();

      // An admin can update any user document.
      allow update: if isAdmin();

      // An admin can delete any user document.
      allow delete: if isAdmin();
    }

    // Rules for the 'exams' collection.
    match /exams/{examId} {
      // Admins, Ejecutivos, and Gestores can read/list exams.
      // (Simplified gestor access for now to avoid complex ownership checks during debugging).
      allow get, list: if request.auth.uid != null &&
                        (isAdmin() ||
                         getRequestingUserRole() == 'ejecutivo' ||
                         getRequestingUserRole() == 'gestor'
                        );

      // Admins and Gestores can create exams.
      allow create: if request.auth.uid != null &&
                        (isAdmin() || getRequestingUserRole() == 'gestor');

      // Admins and Gestores can update exams.
      // (Simplified gestor access for now).
      allow update: if request.auth.uid != null &&
                        (isAdmin() || getRequestingUserRole() == 'gestor'
                        );

      // Only admins can delete exams.
      allow delete: if isAdmin();
    }
  }
}
