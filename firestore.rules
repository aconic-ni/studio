
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function getUserRole(userId) {
      // It's crucial that the user document exists and has a 'role' field.
      // If get() finds no document, .data will be null.
      // If document exists but no 'role' field, .data.role will be null.
      let userData = get(/databases/$(database)/documents/users/$(userId)).data;
      if (userData != null && userData.role != null) {
        return userData.role;
      }
      return null; // Default if no role or no user doc
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole(request.auth.uid) == 'admin';
    }

    function isExecutive() {
      return isAuthenticated() && getUserRole(request.auth.uid) == 'ejecutivo';
    }

    function isGestor() {
      return isAuthenticated() && getUserRole(request.auth.uid) == 'gestor';
    }
    
    // Users Collection
    match /users/{userId} {
      // Authenticated users can read their own profile to get their role.
      allow get: if isOwner(userId);

      // Admins can create user documents for new users.
      // A user could also create their own document if request.auth.uid == userId,
      // useful if you had a separate sign-up page that also creates the Firestore user doc.
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.email == request.auth.email);

      // Only Admins can update user profiles (e.g., to change roles or other details).
      allow update: if isAdmin(); 

      // Only Admins can delete user documents.
      allow delete: if isAdmin();
      
      // Only Admins can list all users.
      allow list: if isAdmin();
    }

    // Exams Collection
    match /exams/{examId} {
      // Admins can read and write (create, update, delete) all exams.
      allow read, write: if isAdmin();

      // Ejecutivos can only read exams (get single or list multiple).
      allow get, list: if isExecutive();

      // Gestores can create exams.
      allow create: if isGestor();
      
      // Gestores can read, update, and delete exams they created.
      // This assumes `resource.data.createdBy` stores the gestor's email.
      // The app currently sets createdBy to examInfo.manager (which is an email/name).
      allow get, list, update, delete: if isGestor() && 
                                        resource.data.createdBy == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.email;
    }
  }
}
